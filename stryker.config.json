{
  "$schema": "https://stryker-mutator.io/schemas/stryker-schema.json#",
  "testRunner": "vitest",
  "testRunnerNodeArgs": [],
  "mutate": [
    "src/utils/**/*.ts",
    "src/hooks/**/*.ts",
    "!src/utils/**/*.test.ts",
    "!src/hooks/**/__tests__/**"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  },
  "timeoutMS": 30000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp",
  "disableTypeChecks": true,
  "checkers": [],
  "vitest": {
    "configFile": "vitest.config.ts"
  }
}
