{
  "name": "vsip-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/clean-ports.js && tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit --skipLibCheck && eslint src",
    "lint:deps": "npx dependency-cruiser src",
    "lint:clones": "npx jscpd src",
    "audit:all": "npm run check-size && npm run lint && npm run lint:deps && npm run lint:clones && npm run test && npm run test:mutation",
    "test:unit": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run tests/unit",
    "test:components": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run src/components",
    "test:contracts": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run tests/unit/contracts.test.ts",
    "test:vitest": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs run",
    "test": "npm run test:vitest && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --headed",
    "test:e2e:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:e2e:responsive": "playwright test tests/e2e/responsive.spec.ts",
    "test:mutation": "stryker run stryker.conf.json",
    "check-size": "node scripts/check-size.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "glob": "^13.0.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.78.0",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "react-virtuoso": "^4.18.7",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.12.1",
    "dependency-cruiser": "^18.0.0",
    "electron": "^42.4.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "memlab": "^2.0.3",
    "msw": "^2.14.6",
    "tailwindcss": "^4.1.14",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.8",
    "vitest-axe": "^0.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}